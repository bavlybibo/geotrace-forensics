# Python runtime/cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments and local tooling
.venv/
venv/
env/

# Build/package outputs
build/
dist/
*.spec.bak

# GeoTrace runtime data - never commit real evidence or generated reports
case_data/*
!case_data/.gitkeep
logs/*
!logs/.gitkeep
exports/
.temp/
report_assets/

# OS/editor noise
.DS_Store
Thumbs.db
*.log
release/
# Keep curated README/product screenshots in version control. Ignore only temp captures.
screenshots/tmp_*.png
!screenshots/.gitkeep
!screenshots/README.md
!screenshots/*.png
